# Copia este archivo como .env.dev o .env y reemplaza los valores.
APP_NAME=keax-portfolio
PORT=8080
SERVER_ADDRESS=127.0.0.1
SERVER_ERROR_INCLUDE_STACKTRACE=never
SERVER_ERROR_INCLUDE_MESSAGE=never
SERVER_ERROR_WHITELABEL_ENABLED=false
SERVER_FORWARD_HEADERS_STRATEGY=none
SERVER_SHUTDOWN=graceful
SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=20s
SERVER_COMPRESSION_ENABLED=true
SERVER_COMPRESSION_MIME_TYPES=application/json,text/plain,text/html,text/css,application/javascript
SERVER_COMPRESSION_MIN_RESPONSE_SIZE=1024

DB_URL=jdbc:postgresql://localhost:5432/keax
DB_USERNAME=replace-me
DB_PASSWORD=replace-me
DB_DRIVER=org.postgresql.Driver
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_MAX_LIFETIME=1800000
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_VALIDATION_TIMEOUT=5000
DB_POOL_KEEPALIVE_TIME=0

JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
JPA_OPEN_IN_VIEW=false
HIBERNATE_JDBC_TIME_ZONE=UTC
JACKSON_TIME_ZONE=UTC

LOGGING_LEVEL_HIBERNATE_SQL=INFO
LOGGING_LEVEL_HIBERNATE_BINDER=INFO
LOGGING_LEVEL_SPRING_WEB=INFO
LOGGING_LEVEL_SPRING_SECURITY=INFO
LOGGING_LEVEL_APP=INFO
LOGGING_LEVEL_CONFIG=INFO

CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
CORS_ALLOW_CREDENTIALS=true
APP_API_URL_FRONTEND=http://localhost:5173

MANAGEMENT_ENDPOINTS_BASE_PATH=/actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_HEALTH_LIVENESS_ENABLED=true
MANAGEMENT_HEALTH_READINESS_ENABLED=true
MANAGEMENT_HEALTH_SHOW_DETAILS=when_authorized
MANAGEMENT_HEALTH_SHOW_COMPONENTS=when_authorized
MANAGEMENT_HEALTH_GROUP_LIVENESS_INCLUDE=livenessState,ping
MANAGEMENT_HEALTH_GROUP_READINESS_INCLUDE=readinessState,db,diskSpace,ping
MANAGEMENT_HEALTH_MAIL_ENABLED=false
MANAGEMENT_PROMETHEUS_ENABLED=true
MANAGEMENT_METRICS_HTTP_HISTOGRAM_ENABLED=true

OPENAPI_ENABLED=true
OPENAPI_DOCS_PATH=/v3/api-docs
SWAGGER_UI_ENABLED=true
SWAGGER_UI_PATH=/swagger-ui.html
SWAGGER_UI_OPERATIONS_SORTER=alpha
SWAGGER_UI_TAGS_SORTER=alpha
OPENAPI_SHOW_ACTUATOR=false

CL_NAME=replace-me
CL_KEY=replace-me
CL_SECRET=replace-me
MULTIPART_MAX_FILE_SIZE=5MB
MULTIPART_MAX_REQUEST_SIZE=5MB

GM_SMTP_STARTTLS_ENABLE=true
GM_SMTP_AUTH=true
GM_HOST=smtp.example.com
GM_PORT=587
GM_USERNAME=replace-me
GM_PASSWORD=replace-me
GM_TRUST=smtp.example.com
GM_CONNECTION_TIMEOUT=5000
GM_TIMEOUT=5000
GM_WRITE_TIMEOUT=5000
GM_TO=replace-me

JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes
JWT_EXP=86400000
CONTACT_RATE_LIMIT_MAX_REQUESTS=3
CONTACT_RATE_LIMIT_WINDOW_MS=600000
CONTACT_RATE_LIMIT_MAX_CLIENTS=10000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_CLIENTS=10000
VISITOR_DEDUPE_WINDOW_MINUTES=30
VISITOR_IP_HASH_SECRET=replace-with-an-independent-secret-of-at-least-32-characters
TRUST_FORWARDED_IP_HEADERS=false
TRUSTED_IP_PROXIES=127.0.0.1,::1
IMAGE_CLEANUP_INITIAL_DELAY_MS=60000
IMAGE_CLEANUP_FIXED_DELAY_MS=300000
